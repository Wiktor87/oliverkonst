# Base path for GitHub Pages deployment (e.g. /oliverkonst)
# Set this as NEXT_PUBLIC_BASE_PATH when building for GitHub Pages.
# For local development, leave empty or unset.
NEXT_PUBLIC_BASE_PATH=

# Fine-grained GitHub PAT for saving orders to data/orders.json.
# Required permissions: Contents (read & write) on this repository only.
# Create at: https://github.com/settings/personal-access-tokens/new
# Store as repository secret named ORDER_TOKEN for production builds.
NEXT_PUBLIC_ORDER_TOKEN=
